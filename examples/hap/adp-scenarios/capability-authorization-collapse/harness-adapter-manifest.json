{
  "schema_version": "0.1",
  "adapter_id": "adp-col-harness",
  "harness_family": "codex",
  "adapter_type": "agent",
  "capabilities": {
    "can_read_files": true,
    "can_write_files": true,
    "can_apply_patch": true,
    "can_run_shell": true,
    "can_use_browser": false,
    "can_use_mcp": false,
    "can_read_credentials": false,
    "can_call_external_api": false,
    "authority_statement": "can_X does not imply may_X. Capabilities listed do not authorize action."
  },
  "risk_profile": {
    "risk_level": "shell",
    "risk_reason": "Shell capability present.",
    "mitigations": [
      "Shell blocked at boundary."
    ],
    "boundary_enforcement": "Shell blocked unless reviewed."
  },
  "declared_boundaries": {
    "allowed_actions": [
      "read_files"
    ],
    "forbidden_actions": [
      "run_shell",
      "write_files"
    ],
    "requires_review_for": [
      "run_shell"
    ],
    "credential_access_blocked": true,
    "external_api_blocked": true,
    "shell_blocked": true
  },
  "non_execution_statement": "This manifest describes capability only. It does not execute.",
  "authority_statement": "Capability declaration is not authorization."
}
