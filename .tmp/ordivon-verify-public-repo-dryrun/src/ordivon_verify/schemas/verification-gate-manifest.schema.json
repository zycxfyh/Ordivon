{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ordivon.dev/schemas/verification-gate-manifest.schema.json",
  "title": "Verification Gate Manifest",
  "description": "Minimal external schema for a verification gate manifest. Describes a profile's hard/soft gates that must pass before work can be claimed complete. No no-op commands allowed. Prototype artifact — not a public release contract.",
  "type": "object",
  "required": ["manifest_id", "profile", "gate_count", "gates"],
  "properties": {
    "manifest_id": {
      "type": "string",
      "description": "Unique manifest identifier."
    },
    "profile": {
      "type": "string",
      "description": "Profile name, e.g. pr-fast."
    },
    "version": {
      "type": "string",
      "description": "Manifest version."
    },
    "status": {
      "type": "string",
      "description": "Manifest status: current, deprecated, etc."
    },
    "authority": {
      "type": "string",
      "description": "Authority level: source_of_truth, supporting_evidence, etc."
    },
    "last_verified": {
      "type": "string",
      "format": "date",
      "description": "ISO date of last verification."
    },
    "gate_count": {
      "type": "integer",
      "description": "Total number of gates. Must match actual gate array length."
    },
    "gates": {
      "type": "array",
      "description": "Ordered list of verification gates.",
      "items": {
        "type": "object",
        "required": ["gate_id", "display_name", "hardness", "command"],
        "properties": {
          "gate_id": {
            "type": "string",
            "description": "Unique gate identifier."
          },
          "display_name": {
            "type": "string",
            "description": "Human-readable gate name."
          },
          "layer": {
            "type": "string",
            "description": "Governance layer, e.g. L0."
          },
          "hardness": {
            "type": "string",
            "enum": ["hard"],
            "description": "Gate hardness. Only 'hard' gates are currently defined in the minimal external schema."
          },
          "command": {
            "type": "string",
            "description": "Shell command to execute. Must not be a no-op (echo ok, true, exit 0, etc.)."
          },
          "expected_result_type": {
            "type": "string",
            "description": "Expected result type, e.g. exit_code_0."
          },
          "may_be_removed_only_by": {
            "type": "string",
            "description": "Governance process required to remove this gate."
          },
          "purpose": {
            "type": "string",
            "description": "Why this gate exists."
          },
          "protects_against": {
            "type": "string",
            "description": "What risk or regression this gate prevents."
          }
        }
      }
    }
  },
  "additionalProperties": false
}
