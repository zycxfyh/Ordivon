{
  "name": "ordivon-web",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{ recursive: true, force: true })\"",
    "dev": "next dev",
    "dev:quality": "pnpm clean && next dev",
    "build": "next build",
    "build:quality": "pnpm clean && next build",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "next": "15.5.15",
    "react": "18.3.1",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitejs/plugin-react": "^5.0.4",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^19.2.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^27.0.1",
    "typescript": "^5.5.0",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
