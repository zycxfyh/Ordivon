# .gitignore for PFIOS

# Python
__pycache__/
*.py[cod]
*$py.class
.venv
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Node
node_modules/
dist/
.next/
out/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Database & Data
db/*.duckdb
db/*.db
db/*.sqlite
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Env & Secrets
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db
